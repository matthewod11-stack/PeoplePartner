{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "People Partner",
  "identifier": "com.peoplepartner.app",
  "version": "0.2.2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "People Partner",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:1420 ws://localhost:1420; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: Matthew O'Donnell (NNC7N645Q8)",
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBCNDMwRjhDNkNDRkEwRkMKUldUOG9NOXNqQTlEQ3lucWhKK2FxUGl6cnphdHJRWVFqRWNJVTNnWE1JdVlobFg4V2VVN3FqeHIK",
      "endpoints": [
        "https://github.com/matthewod11-stack/PeoplePartner/releases/latest/download/latest.json"
      ]
    }
  }
}
